<div class="d-flex justify-content-between align-items-center mb-4 mt-3">
    <h2>Browse Items</h2>
    <% if(user) { %>
        <a href="/items/new" class="btn btn-success">Sell an Item</a>
    <% } %>
</div>

<!-- Search Form -->
<form action="/items" method="GET" class="mb-4">
    <div class="row g-2">
        <div class="col-md-5">
            <input type="text" name="keyword" class="form-control" placeholder="Search by title..." value="<%= searchQuery.keyword || '' %>">
        </div>
        <div class="col-md-3">
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                <option value="Cars" <%= searchQuery.category === 'Cars' ? 'selected' : '' %>>Cars</option>
                <option value="Bikes" <%= searchQuery.category === 'Bikes' ? 'selected' : '' %>>Bikes</option>
                <option value="Electronics" <%= searchQuery.category === 'Electronics' ? 'selected' : '' %>>Electronics</option>
                <option value="Furniture" <%= searchQuery.category === 'Furniture' ? 'selected' : '' %>>Furniture</option>
                <option value="Other" <%= searchQuery.category === 'Other' ? 'selected' : '' %>>Other</option>
            </select>
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Search</button>
        </div>
        <div class="col-md-2">
            <a href="/items" class="btn btn-outline-secondary w-100">Clear</a>
        </div>
    </div>
</form>

<div class="row">
    <% if (items.length === 0) { %>
        <div class="col-12 text-center">
            <p class="lead">No items found.</p>
        </div>
    <% } else { %>
        <% items.forEach(item => { %>
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <% if(item.imageUrl === 'no-photo.jpg') { %>
                        <div class="bg-secondary text-white text-center d-flex align-items-center justify-content-center" style="height: 200px;">
                            <span>No Image</span>
                        </div>
                    <% } else { %>
                        <img src="/uploads/<%= item.imageUrl %>" class="card-img-top" alt="<%= item.title %>" style="height: 200px; object-fit: cover;">
                    <% } %>
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-truncate"><%= item.title %></h5>
                        <h6 class="card-subtitle mb-2 text-primary">$<%= item.price %></h6>
                        <p class="card-text small text-muted"><%= item.category %></p>
                        <p class="card-text text-truncate"><%= item.description %></p>
                        <div class="mt-auto">
                            <a href="/items/<%= item._id %>" class="btn btn-outline-primary w-100">View Details</a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<!-- Pagination -->
<% if (pagination.next || pagination.prev) { %>
    <nav aria-label="Page navigation" class="mt-4">
        <ul class="pagination justify-content-center">
            <% if (pagination.prev) { %>
                <li class="page-item">
                    <a class="page-link" href="/items?page=<%= pagination.prev.page %>&limit=<%= pagination.prev.limit %><%= searchQuery.keyword ? '&keyword='+searchQuery.keyword : '' %><%= searchQuery.category ? '&category='+searchQuery.category : '' %>">Previous</a>
                </li>
            <% } else { %>
                <li class="page-item disabled"><span class="page-link">Previous</span></li>
            <% } %>

            <% if (pagination.next) { %>
                <li class="page-item">
                    <a class="page-link" href="/items?page=<%= pagination.next.page %>&limit=<%= pagination.next.limit %><%= searchQuery.keyword ? '&keyword='+searchQuery.keyword : '' %><%= searchQuery.category ? '&category='+searchQuery.category : '' %>">Next</a>
                </li>
            <% } else { %>
                <li class="page-item disabled"><span class="page-link">Next</span></li>
            <% } %>
        </ul>
    </nav>
<% } %>
