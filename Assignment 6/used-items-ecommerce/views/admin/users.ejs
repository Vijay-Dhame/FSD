<div class="row mt-4">
    <div class="col-md-3">
        <%- include('../partials/admin_sidebar') %>
    </div>
    
    <div class="col-md-9">
        <h2>Manage Users</h2>
        
        <div class="table-responsive mt-3">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Joined</th>
                    </tr>
                </thead>
                <tbody>
                    <% users.forEach(user => { %>
                        <tr>
                            <td><%= user.name %></td>
                            <td><%= user.email %></td>
                            <td>
                                <% if (user.role === 'admin') { %>
                                    <span class="badge bg-danger"><%= user.role.toUpperCase() %></span>
                                <% } else { %>
                                    <span class="badge bg-primary"><%= user.role.toUpperCase() %></span>
                                <% } %>
                            </td>
                            <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
