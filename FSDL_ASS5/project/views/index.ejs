<%- include('./partials/header.ejs') %>

<section class="hero">
  <div class="hero-content">
    <h1>Explore the World with <span>Wanderlust</span></h1>
    <p class="tagline">Your ultimate travel partner for unforgettable experiences. We curate premium destinations just for you.</p>
    <a href="/packages" class="btn primary-btn">View All Packages</a>
  </div>
</section>

<section class="featured-packages">
  <div class="section-title">
    <h2>Featured Destinations</h2>
    <div class="underline"></div>
  </div>
  
  <div class="cards-container">
    <% if (featuredPackages && featuredPackages.length > 0) { %>
      <% featuredPackages.forEach(pkg => { %>
        <div class="card glass">
          <div class="card-body">
            <h3><%= pkg.title %></h3>
            <p class="destination"><i class="icon-map-pin"></i> <%= pkg.destination %></p>
            <p class="duration"><%= pkg.duration %></p>
            <p class="description"><%= pkg.description.substring(0, 100) %>...</p>
            <div class="card-footer">
              <span class="price">$<%= pkg.price %></span>
              <a href="/contact?package=<%= pkg._id %>" class="btn secondary-btn">Inquire</a>
            </div>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="no-data glass">
        <p>No featured packages found. Be the first to add one!</p>
        <a href="/add-package" class="btn primary-btn mt-1">Add Package</a>
      </div>
    <% } %>
  </div>
</section>

<%- include('./partials/footer.ejs') %>
