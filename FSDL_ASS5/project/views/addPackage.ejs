<%- include('./partials/header.ejs') %>

<section class="admin-page">
  <div class="form-container glass">
    <h2>Add New Package</h2>
    <p>Create a new travel destination package</p>
    
    <form action="/add-package" method="POST" class="standard-form">
      <div class="form-group">
        <label for="title">Package Title</label>
        <input type="text" id="title" name="title" required placeholder="e.g. Bali Bliss Gateway">
      </div>
      
      <div class="form-group">
        <label for="destination">Destination</label>
        <input type="text" id="destination" name="destination" required placeholder="e.g. Bali, Indonesia">
      </div>

      <div class="form-row">
        <div class="form-group half">
          <label for="price">Price ($)</label>
          <input type="number" id="price" name="price" required placeholder="e.g. 1500" min="0">
        </div>
        
        <div class="form-group half">
          <label for="duration">Duration</label>
          <input type="text" id="duration" name="duration" required placeholder="e.g. 7 Days, 6 Nights">
        </div>
      </div>

      <div class="form-group">
        <label for="description">Description</label>
        <textarea id="description" name="description" rows="5" required placeholder="Describe the wonderful experience..."></textarea>
      </div>

      <button type="submit" class="btn primary-btn full-width">Save Package</button>
    </form>
  </div>
</section>

<%- include('./partials/footer.ejs') %>
